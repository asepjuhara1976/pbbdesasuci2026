rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - deny anything else
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Taxpayers Collection
    match /taxpayers/{nop} {
      // In PBB System, any user can search/read tax objects to check invoices, or look up geographic persil on the map.
      allow read, list: if true;
      
      // Allow create and update if document schema is valid (since simulation user-roles are stored client-side in localStorage)
      allow create, update: if isValidTaxpayer(incoming());
      
      // Allow delete for any simulated admin/petugas request
      allow delete: if true;
    }

    // Payment Logs Collection
    match /payment_logs/{logId} {
      allow read, list: if true; // Public list of global transactions ticker
      allow create: if isValidPaymentLog(incoming());
      allow update, delete: if true;
    }

    // Entity-Specific Validation Helpers
    function isValidTaxpayer(data) {
      // Core fields that must be present and valid
      return data.keys().hasAll(['id', 'name', 'landArea', 'njopLand', 'totalTax', 'isPaid', 'lat', 'lng', 'updatedAt'])
        && data.id is string && data.id.size() <= 100
        && data.name is string && data.name.size() <= 200
        && data.landArea is number
        && data.njopLand is number
        && data.totalTax is number
        && data.isPaid is bool
        && data.lat is number
        && data.lng is number
        && data.updatedAt is string
        // Optional or nullable fields to handle omission, partial imports, or nullish properties under client serialization
        && (!data.keys().hasAny(['address']) || data.address == null || (data.address is string && data.address.size() <= 600))
        && (!data.keys().hasAny(['objectAddress']) || data.objectAddress == null || (data.objectAddress is string && data.objectAddress.size() <= 600))
        && (!data.keys().hasAny(['buildingArea']) || data.buildingArea == null || data.buildingArea is number)
        && (!data.keys().hasAny(['njopBuilding']) || data.njopBuilding == null || data.njopBuilding is number)
        && (!data.keys().hasAny(['polygonCoords']) || data.polygonCoords == null || data.polygonCoords is list)
        && (!data.keys().hasAny(['paymentDate']) || data.paymentDate == null || data.paymentDate is string)
        && (!data.keys().hasAny(['paymentMethod']) || data.paymentMethod == null || data.paymentMethod is string);
    }

    function isValidPaymentUpdate() {
      // Allow only transitioning 'isPaid' status and details of payment
      return incoming().isPaid == true 
             && incoming().id == existing().id
             && incoming().name == existing().name;
    }

    function isValidPaymentLog(data) {
      return data.keys().hasAll(['id', 'nop', 'taxpayerName', 'amount', 'method', 'timestamp'])
        && data.id is string && data.id.size() <= 128
        && data.nop is string && data.nop.size() <= 100
        && data.taxpayerName is string && data.taxpayerName.size() <= 200
        && data.amount is number
        && data.method is string
        && data.timestamp is string;
    }
  }
}
